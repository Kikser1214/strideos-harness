# Optional. Without a key, StrideOS runs in deterministic judge demo mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
PORT=4173
HOST=127.0.0.1

# Required when HOST exposes StrideOS beyond this computer. Use a long random
# value and enter it in the private companion unlock screen.
STRIDEOS_ACCESS_TOKEN=
STRIDEOS_PUBLIC_URL=

# Provider sessions are not configured in this file. If a future playbook
# explicitly permits attended agent operation, the athlete signs in on the
# provider page and StrideOS never stores credentials or session material.
# No current Garmin browser-agent read or write route is claimed.

# Optional state location. Defaults to the operating system temp directory.
STRIDEOS_STATE_FILE=
