# Optional. Without a key, StrideOS runs in deterministic judge demo mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
PORT=4173
HOST=127.0.0.1

# Required when HOST exposes StrideOS beyond this computer. Use a long random
# value and enter it in the private companion unlock screen.
STRIDEOS_ACCESS_TOKEN=
STRIDEOS_PUBLIC_URL=

# Optional adapter. Without this, approved Garmin writes are explicitly simulated.
GARMIN_BRIDGE_URL=
GARMIN_BRIDGE_TOKEN=

# Optional local-only adapter for a user-supplied and reviewed community Python
# workout script. Do not put Garmin email/password in this harness file.
GARMIN_COMMUNITY_PUSH_SCRIPT=
GARMIN_COMMUNITY_TOKEN_DIR=
GARMIN_COMMUNITY_PYTHON=python
GARMIN_COMMUNITY_BRIDGE_HOST=127.0.0.1
GARMIN_COMMUNITY_BRIDGE_PORT=8787

# Optional Strava OAuth setup contract. The UI reports setup readiness only;
# it never labels an athlete connected until a complete OAuth flow proves it.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:4173/api/strava/callback

# Optional state location. Defaults to the operating system temp directory.
STRIDEOS_STATE_FILE=
